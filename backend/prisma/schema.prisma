// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== CLIENTES ====================
model Client {
  id          String   @id @default(uuid())
  // Identificação
  name        String
  type        String   @default("PF") // PF ou PJ
  cpfCnpj     String?  // CPF ou CNPJ
  // Contato
  email       String?
  phone       String?  // Celular / WhatsApp principal
  phone2      String?  // Telefone fixo / alternativo
  instagram   String?  // @ do Instagram
  // Endereço
  zipCode     String?  // CEP
  street      String?  // Logradouro
  number      String?  // Número
  complement  String?  // Complemento
  neighborhood String? // Bairro
  city        String?  // Cidade
  state       String?  // UF
  address     String?  // Campo legado / endereço completo
  // Extras
  notes       String?  // Observações internas
  isVip       Boolean  @default(false) // Cliente VIP / prioritário
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders Order[]

  @@map("clients")
}

// ==================== PEDIDOS (PAI) ====================
enum OrderStatus {
  PENDING
  IN_PRODUCTION
  FINISHED
  WAITING_CONFIRMATION
  SHIPPED
  DELIVERED
  CANCELLED
}


model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique
  clientId        String?
  deliveryDate    DateTime
  notes           String?
  status          OrderStatus @default(PENDING)
  isPriority      Boolean     @default(false)
  createdAt       DateTime    @default(now())

  updatedAt       DateTime    @updatedAt

  client          Client?     @relation(fields: [clientId], references: [id])

  items           OrderItem[]
  alerts          Alert[]

  @@index([status, deliveryDate])
  @@map("orders")
}

// ==================== ITENS/PEÇAS DO PEDIDO ====================
model OrderItem {
  id              String      @id @default(uuid())
  orderId         String?

  productId       String      // ID do produto cadastrado no catálogo
  productName     String      // Nome copiado para histórico
  customization   String?     
  quantity        Int         @default(1)
  status          String      @default("WAITING") // WAITING, IN_PRODUCTION, COMPLETED
  priorityRank    Int         @default(0)
  isStarted       Boolean     @default(false)
  isPicked        Boolean     @default(false)
  isStock         Boolean     @default(false)


  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  order           Order?      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product     @relation(fields: [productId], references: [id])
  productionSteps ProductionStep[]
  stockMovements  StockMovement[]

  @@map("order_items")
}

// ==================== CATÁLOGO DE PRODUTOS/MODELOS ====================
model Product {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  colors      Json?       // Array de strings hex: ["#FF0000", "#00FF00"]
  details     Json?       // Array de atributos: ["Vidro 6mm", "Jateado"]
  imageUrl    String?     // Caminho relativo da foto: "uploads/products/uuid.jpg"
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orderItems  OrderItem[]

  @@map("products")
}

// ==================== ETAPAS DE PRODUÇÃO (AGORA VINCULADAS AO ITEM) ====================
// As etapas agora são dinâmicas e definidas pelo usuário via templates
model ProductionStepTemplate {
  id               String   @id @default(uuid())
  name             String   @unique
  stepOrder        Int      @default(0)
  estimatedMinutes Int      @default(60)
  isActive         Boolean  @default(true)
  color            String?  // Ex: #FF0000
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  productionSteps  ProductionStep[]
  checklistItems   ChecklistItemTemplate[]

  @@map("production_step_templates")
}

model ChecklistItemTemplate {
  id               String   @id @default(uuid())
  text             String
  isMandatory      Boolean  @default(true)
  stepTemplateId   String
  createdAt        DateTime @default(now())

  stepTemplate     ProductionStepTemplate @relation(fields: [stepTemplateId], references: [id], onDelete: Cascade)

  @@map("checklist_item_templates")
}




enum StepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

model ProductionStep {
  id              String     @id @default(uuid())
  orderItemId     String     // Vinculado à peça específica
  stepTemplateId  String?    // Vinculado ao template original (opcional para manter flexibilidade)
  stepName        String     // Nome da etapa (salvo como string para suportar mudanças no template)
  stepOrder       Int
  status          StepStatus @default(PENDING)
  completedQuantity Int      @default(0)
  estimatedMinutes Int       @default(60)

  startedAt       DateTime?
  completedAt     DateTime?
  assignedTo      String?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  item            OrderItem               @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  template        ProductionStepTemplate? @relation(fields: [stepTemplateId], references: [id])
  checklistItems  ChecklistItem[]

  @@unique([orderItemId, stepName])
  @@index([status, stepName])
  @@map("production_steps")
}

model ChecklistItem {
  id               String   @id @default(uuid())
  text             String
  isMandatory      Boolean  @default(true)
  isChecked        Boolean  @default(false)
  productionStepId String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  productionStep   ProductionStep @relation(fields: [productionStepId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
}


// ==================== ESTOQUE ====================
enum UnitType {
  KG
  LITERS
  UNITS
  METERS
  SHEETS
}

model Material {
  id             String    @id @default(uuid())
  name           String
  description    String?
  unit           UnitType
  currentStock   Decimal   @default(0) @db.Decimal(10, 3)
  minimumStock   Decimal   @default(0) @db.Decimal(10, 3)
  costPerUnit    Decimal?  @db.Decimal(10, 2)
  supplier       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  stockMovements StockMovement[]

  @@map("materials")
}

enum MovementType {
  ENTRY
  EXIT
  ADJUSTMENT
}

model StockMovement {
  id          String       @id @default(uuid())
  materialId  String
  orderItemId String?
  type        MovementType
  quantity    Decimal      @db.Decimal(10, 3)
  reason      String?
  createdAt   DateTime     @default(now())

  material    Material     @relation(fields: [materialId], references: [id])
  item        OrderItem?   @relation(fields: [orderItemId], references: [id])

  @@map("stock_movements")
}

// ==================== ALERTAS ====================
enum AlertType {
  DEADLINE_APPROACHING
  STEP_DELAYED
  LOW_STOCK
  ORDER_DELAYED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model Alert {
  id        String        @id @default(uuid())
  type      AlertType
  severity  AlertSeverity @default(WARNING)
  title     String
  message   String
  orderId   String?
  isRead    Boolean       @default(false)
  createdAt DateTime      @default(now())

  order     Order?        @relation(fields: [orderId], references: [id])

  @@map("alerts")
}

// ... (anteriores)

// ==================== USUÁRIOS E SEGURANÇA ====================
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   // Hash da senha
  role      String   @default("ADMIN") 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model StepConfig {
  id               String   @id @default(uuid())
  stepName         String   @unique
  estimatedMinutes Int
  description      String?
  updatedAt        DateTime @updatedAt

  @@map("step_configs")
}
