// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== CLIENTES ====================
model Client {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@map("clients")
}

// ==================== PEDIDOS (PAI) ====================
enum OrderStatus {
  PENDING
  IN_PRODUCTION
  FINISHED
  DELIVERED
  CANCELLED
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique
  clientId        String
  deliveryDate    DateTime
  notes           String?
  status          OrderStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  client          Client      @relation(fields: [clientId], references: [id])
  items           OrderItem[]
  alerts          Alert[]

  @@map("orders")
}

// ==================== ITENS/PEÇAS DO PEDIDO ====================
model OrderItem {
  id              String      @id @default(uuid())
  orderId         String
  productId       String      // ID do produto cadastrado no catálogo
  productName     String      // Nome copiado para histórico
  customization   String?     
  quantity        Int         @default(1)
  status          String      @default("PENDING")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product     @relation(fields: [productId], references: [id])
  productionSteps ProductionStep[]
  stockMovements  StockMovement[]

  @@map("order_items")
}

// ==================== CATÁLOGO DE PRODUTOS/MODELOS ====================
model Product {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orderItems  OrderItem[]

  @@map("products")
}

// ==================== ETAPAS DE PRODUÇÃO (AGORA VINCULADAS AO ITEM) ====================
enum StepName {
  CUTTING      // Corte
  MOLDING      // Modelagem
  COOLING      // Resfriamento
  FINISHING    // Acabamento
  PACKAGING    // Embalagem
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

model ProductionStep {
  id              String     @id @default(uuid())
  orderItemId     String     // Vinculado à peça específica
  stepName        StepName
  stepOrder       Int
  status          StepStatus @default(PENDING)
  estimatedMinutes Int       @default(60)
  startedAt       DateTime?
  completedAt     DateTime?
  assignedTo      String?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  item            OrderItem  @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@unique([orderItemId, stepName])
  @@map("production_steps")
}

// ==================== ESTOQUE ====================
enum UnitType {
  KG
  LITERS
  UNITS
  METERS
  SHEETS
}

model Material {
  id             String    @id @default(uuid())
  name           String
  description    String?
  unit           UnitType
  currentStock   Decimal   @default(0) @db.Decimal(10, 3)
  minimumStock   Decimal   @default(0) @db.Decimal(10, 3)
  costPerUnit    Decimal?  @db.Decimal(10, 2)
  supplier       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  stockMovements StockMovement[]

  @@map("materials")
}

enum MovementType {
  ENTRY
  EXIT
  ADJUSTMENT
}

model StockMovement {
  id          String       @id @default(uuid())
  materialId  String
  orderItemId String?
  type        MovementType
  quantity    Decimal      @db.Decimal(10, 3)
  reason      String?
  createdAt   DateTime     @default(now())

  material    Material     @relation(fields: [materialId], references: [id])
  item        OrderItem?   @relation(fields: [orderItemId], references: [id])

  @@map("stock_movements")
}

// ==================== ALERTAS ====================
enum AlertType {
  DEADLINE_APPROACHING
  STEP_DELAYED
  LOW_STOCK
  ORDER_DELAYED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model Alert {
  id        String        @id @default(uuid())
  type      AlertType
  severity  AlertSeverity @default(WARNING)
  title     String
  message   String
  orderId   String?
  isRead    Boolean       @default(false)
  createdAt DateTime      @default(now())

  order     Order?        @relation(fields: [orderId], references: [id])

  @@map("alerts")
}

model StepConfig {
  id               String   @id @default(uuid())
  stepName         StepName @unique
  estimatedMinutes Int
  description      String?
  updatedAt        DateTime @updatedAt

  @@map("step_configs")
}
