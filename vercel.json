{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "http://localhost:3001/api/$1" },
    { "source": "/((?!assets|.*\\..*).*)", "destination": "/frontend/index.html" }
  ]
}
