{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "http://localhost:3001/api/$1" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
